ENV['VAGRANT_DEFAULT_PROVIDER'] = 'libvirt'

Vagrant.configure("2") do |config|

  config.vm.synced_folder "../00-config/", "/00-config", type: "rsync", rsync__exclude: ".vagrant/", rsync__auto: true
  config.vm.synced_folder ".", "/vagrant", type: "rsync", rsync__exclude: ".vagrant/", rsync__auto: true

  config.vm.define "centosldap" do |centosldap|
    centosldap.vm.hostname = "ldap.vagrant.local"
    centosldap.vm.box = "generic/centos7"
    centosldap.vm.synced_folder "../00-config/", "/00-config", type: "rsync", rsync__exclude: ".vagrant/", rsync__auto: true
    centosldap.vm.synced_folder ".", "/vagrant", type: "rsync", rsync__exclude: ".vagrant/", rsync__auto: true
    centosldap.vm.provision "shell", path: "./bootstrap-ldap.sh"
    centosldap.vm.provider :libvirt do |v|
      v.memory = 256
      v.cpus = 1
    end
  end

  config.vm.define "ldapreset" do |ldapreset|
    ldapreset.vm.hostname = "ldapreset.vagrant.local"
    ldapreset.vm.box = "generic/centos8"
    ldapreset.vm.provider :libvirt do |v|
      v.memory = 256
      v.cpus = 1
    end
  end

end